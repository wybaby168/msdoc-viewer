{
  "name": "msdoc-viewer",
  "version": "0.4.1",
  "description": "Strict TypeScript MS-DOC (.doc) reader and HTML/CSS renderer with optional Web Worker support.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "demo",
    "README.md"
  ],
  "keywords": [
    "doc",
    "ms-doc",
    "ole",
    "cfb",
    "word",
    "viewer",
    "html"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "npm run build && node ./test/smoke.mjs",
    "test": "npm run smoke",
    "ci": "npm run typecheck && npm run smoke"
  },
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/wybaby168/msdoc-viewer.git"
  },
  "homepage": "https://github.com/wybaby168/msdoc-viewer",
  "bugs": {
    "url": "https://github.com/wybaby168/msdoc-viewer/issues"
  }
}
